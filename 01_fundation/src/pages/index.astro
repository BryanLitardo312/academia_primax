---
//Server only
const name='Bryan Rodríguez Litardo';
import Navbar from '../components/Navbar.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{name}</title>
	</head>
	<body>
		<Navbar />
		<h1>Bienvenido</h1>
		<p>Momento actual: {new Date().toLocaleTimeString()}</p>
		<p id="current-time">Momento actual real: </p>
		<footer>Año 2023</footer>
		<script>
			const footer = document.querySelector('footer') as HTMLElement;
			const currentTimeParagraph = document.querySelector('#current-time') as HTMLParagraphElement;
			
			const currentYear: number = new Date().getFullYear();
			
			footer.innerText = `Año: ${currentYear}`;
			currentTimeParagraph.innerText = `Momento actual real: ${new Date().toLocaleTimeString()}`;

		</script>
	</body>
</html>
